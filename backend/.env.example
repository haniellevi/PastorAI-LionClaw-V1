# PastorAI backend — example environment (SPEC 5.3)
# Copy to .env and fill real values. NEVER commit real secrets.

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Clerk (Auth - US-01 / RNF-01)
CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_JWT_ISSUER=https://clerk.pastorai.com.br
# Optional: explicit JWKS endpoint (derived from issuer when empty)
CLERK_JWKS_URL=

# Supabase (Postgres + RLS - US-02 / RNF-02)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
DATABASE_URL=postgresql://user:pass@host:5432/pastorai

# Criptografia de segredos (RNF-03)
SECRETS_ENCRYPTION_KEY=base64_32_bytes_key

# Evolution API (WhatsApp - US-05..US-08)
EVOLUTION_API_URL=https://evo.pastorai.com.br
EVOLUTION_API_KEY=xxx
EVOLUTION_WEBHOOK_SECRET=xxx

# Worker / Filas (RNF-17)
REDIS_URL=redis://localhost:6379/0

# Agente Orquestrador / LLM BYO (US-08/US-27 - delta-034)
# Chave default opcional; cada igreja usa a propria cifrada no banco (RNF-03/20)
OPENAI_API_KEY=
# Checkpoint do grafo LangGraph (RNF-08/15); vazio usa store em memoria
AGENT_GRAPH_CHECKPOINT_URL=
# Modelo default do orquestrador quando a igreja nao sobrescreve
AGENT_DEFAULT_MODEL=gpt-4o-mini
# Versao atual do termo LGPD; alterar forca re-aceite (delta-040)
AGENT_TERM_VERSION=v1

# SLA engine + cron worker (O5)
# Intervalo (segundos) entre ciclos do cron_worker (varredura SLA + crons)
CRON_TICK_SECONDS=300
# Modelo default do assistente do painel (api-assistant); reusa a credencial BYO
ASSISTANT_DEFAULT_MODEL=gpt-4o-mini

# Asaas (assinatura/billing - US-36/RF-42)
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
# Token compartilhado para validar webhooks Asaas (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
# Taxa de setup cobrada no primeiro checkout (BRL)
ASAAS_SETUP_FEE=0

# Brevo / ex-Sendinblue (convites de equipe - RF-40)
# Chave em https://app.brevo.com/settings/keys/api ; remetente precisa de
# domínio/sender verificado em https://app.brevo.com/senders
BREVO_API_URL=https://api.brevo.com/v3
BREVO_API_KEY=
BREVO_FROM_EMAIL=no-reply@pastorai.com.br
BREVO_FROM_NAME=PastorAI

# Google Calendar (sync de eventos - RF-39)
GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
