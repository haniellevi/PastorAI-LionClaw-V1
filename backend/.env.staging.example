# =============================================================================
# PastorAI backend — exemplo de ambiente de STAGING (B1 — staging isolado)
# -----------------------------------------------------------------------------
# Copie para `.env` no ambiente de staging e preencha os valores reais. NUNCA
# commitar o `.env` real (o .gitignore já cobre). Este arquivo NÃO contém
# segredos — apenas placeholders.
#
# Regra de ouro do B1: staging usa um PROJETO SUPABASE DEDICADO e uma INSTÂNCIA
# CLERK DEV/TEST — jamais as credenciais de produção. Veja deploy/STAGING.md.
#
# Legenda dos blocos:
#   [ISOLAR] valor EXCLUSIVO de staging (≠ produção, sem exceção)
#   [VAZIO]  deixar em branco nesta fase — serviço externo desligado (o guard
#            formal contra envios reais é o B2, ainda não implementado)
#   [DEFAULT] pode manter o default do código; preencher só se quiser sobrescrever
# =============================================================================

# ---- App --------------------------------------------------------------------
# [ISOLAR] `staging` mantém assert_production_ready() tolerante (não exige todos
# os secrets) — NÃO use `production` aqui.
APP_ENV=staging
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---- Clerk (Auth - US-01 / RNF-01) — INSTÂNCIA DEV/TEST ---------------------
# [ISOLAR] Use chaves de TESTE (pk_test_/sk_test_), nunca pk_live/sk_live.
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWT_ISSUER=https://<sua-instancia-dev>.clerk.accounts.dev
# [DEFAULT] derivado do issuer quando vazio.
CLERK_JWKS_URL=

# ---- Supabase (Postgres + RLS - US-02 / RNF-02) — PROJETO DEDICADO ----------
# [ISOLAR] O `ref` do projeto de staging tem de ser DIFERENTE do de produção.
SUPABASE_URL=https://<staging-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ_staging_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ_staging_xxx
# Connection string do POOLER do projeto de staging (Supavisor): usuário no
# formato postgres.<staging-ref>, host <region>.pooler.supabase.com, porta 6543
# (transaction) ou 5432 (session). Senha percent-encoded.
DATABASE_URL=postgresql://postgres.<staging-ref>:<senha>@<region>.pooler.supabase.com:6543/postgres

# ---- Criptografia de segredos (RNF-03) --------------------------------------
# [ISOLAR] Gere uma chave Fernet NOVA só para staging (as BYO keys cifradas não
# devem cruzar ambientes). Ex.: Fernet.generate_key().decode()
SECRETS_ENCRYPTION_KEY=<fernet_key_staging>

# ---- Sessão do painel (JWT emitido pelo backend) ----------------------------
# [ISOLAR] segredo próprio; quando vazio, cai no CLERK_SECRET_KEY (de staging).
SESSION_JWT_SECRET=
SESSION_TTL_HOURS=8
PASSWORD_RESET_TTL_MINUTES=30

# ---- Evolution API (WhatsApp) — DESLIGADA nesta fase ------------------------
# [VAZIO] Sem credencial → nenhuma mensagem de WhatsApp entra ou sai em staging.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_WEBHOOK_CALLBACK_URL=

# ---- Worker / Filas (RNF-17) ------------------------------------------------
# [ISOLAR] Redis próprio de staging (db/instância separados de produção).
REDIS_URL=redis://localhost:6379/0

# ---- Agente Orquestrador / LLM BYO — DESLIGADO nesta fase -------------------
# [VAZIO] sem chave default; cada igreja traria a sua cifrada (não nesta fase).
OPENAI_API_KEY=
# [VAZIO] vazio usa checkpointer em memória.
AGENT_GRAPH_CHECKPOINT_URL=
# [DEFAULT]
AGENT_DEFAULT_MODEL=gpt-4o-mini
AGENT_TERM_VERSION=v1

# ---- SLA engine + cron worker (O5) ------------------------------------------
# [DEFAULT]
CRON_TICK_SECONDS=300
ASSISTANT_DEFAULT_MODEL=gpt-4o-mini

# ---- Asaas (billing) — DESLIGADO nesta fase ---------------------------------
# [DEFAULT] URL pública; [VAZIO] sem chave/token → nenhuma cobrança real.
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SETUP_FEE=0

# ---- Brevo (e-mail de convite) — DESLIGADO nesta fase -----------------------
# [DEFAULT] URL/remetente; [VAZIO] sem chave → nenhum e-mail real é enviado.
BREVO_API_URL=https://api.brevo.com/v3
BREVO_API_KEY=
BREVO_FROM_EMAIL=no-reply@igreja12.com.br
BREVO_FROM_NAME=Igreja 12

# ---- Google Calendar / OAuth — DESLIGADO nesta fase -------------------------
# [DEFAULT] URLs públicas; [VAZIO] sem token/credencial → sem sync real.
GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
