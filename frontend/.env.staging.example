# =============================================================================
# PastorAI frontend (Next.js) — exemplo de ambiente de STAGING (B1)
# -----------------------------------------------------------------------------
# Copie para `.env.local` (dev local) ou configure como variáveis do ambiente de
# Preview na Vercel. NÃO commitar valores reais — este arquivo só tem placeholders.
#
# Apontar SEMPRE para a API e a instância Clerk de STAGING — nunca produção.
# =============================================================================

# Backend FastAPI de staging (api-login, /auth/me). Local: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk — chave PUBLICÁVEL de TESTE (pk_test_), nunca pk_live_. Sem chave, o app
# roda em modo backend-only (login continua via api-login, validado no servidor).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
